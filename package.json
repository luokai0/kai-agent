{
  "name": "kai-agent",
  "version": "1.0.0",
  "description": "Neural AI Brain with Real Embeddings, Tree of Thoughts, and HuggingFace Knowledge",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "kai": "./dist/cli/start.js"
  },
  "scripts": {
    "start": "bun run src/start.ts",
    "dev": "bun run src/start.ts",
    "build": "tsc",
    "train": "bun run train.ts",
    "train:quick": "bun run train.ts --quick",
    "train:full": "bun run train.ts --epochs 100 --batch 64",
    "download": "python3 scripts/download_hf_data.py",
    "ingest": "bun run src/ingestion/ingest.ts",
    "test": "node --test dist/**/*.test.js",
    "cli": "bun run src/cli/start.ts",
    "repl": "bun run src/start.ts"
  },
  "keywords": [
    "neural-network",
    "ai",
    "agent",
    "memory",
    "tree-of-thoughts",
    "cybersecurity",
    "coding",
    "embeddings",
    "bert",
    "huggingface"
  ],
  "dependencies": {
    "@xenova/transformers": "^2.17.2",
    "better-sqlite3": "^11.0.0",
    "chalk": "^5.3.0",
    "commander": "^12.0.0",
    "onnxruntime-node": "^1.24.3",
    "uuid": "^10.0.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.11",
    "@types/node": "^22.0.0",
    "@types/uuid": "^10.0.0",
    "tsx": "^4.21.0",
    "typescript": "^5.6.0"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
